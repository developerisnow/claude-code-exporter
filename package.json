{
  "name": "claude-code-exporter",
  "version": "2.0.0",
  "description": "Export and aggregate Claude Code conversation sessions with TypeScript support",
  "author": "",
  "license": "MIT",
  "bin": {
    "claude-prompts": "./bin/claude-prompts",
    "claude-export": "./bin/claude-prompts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typeorm": "env-cmd ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- --dataSource=src/database/data-source.ts migration:generate",
    "postmigration:generate": "npm run lint -- --fix",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- --dataSource=src/database/data-source.ts migration:run",
    "migration:revert": "npm run typeorm -- --dataSource=src/database/data-source.ts migration:revert",
    "schema:drop": "npm run typeorm -- --dataSource=src/database/data-source.ts schema:drop",
    "prebuild": "rimraf dist",
    "build": "nest build && npm run build:cli",
    "build:cli": "cp dist/main.js dist/cli.js && chmod +x dist/cli.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:complexity": "eslint \"{src,apps,libs,test}/**/*.ts\" --config .eslintrc.complexity.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "env-cmd jest --config ./test/jest-e2e.json",
    "prepare": "is-ci || echo 'Skipping husky setup'",
    "release": "release-it"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.2.8",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^10.0.0",
    "apple-signin-auth": "^2.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "16.5.0",
    "fb": "^2.0.0",
    "google-auth-library": "^10.1.0",
    "ms": "^2.1.3",
    "nest-commander": "^3.17.0",
    "ora": "^5.4.1",
    "pg": "8.16.2",
    "readline-sync": "^1.4.10",
    "reflect-metadata": "0.2.2",
    "rimraf": "^5.0.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.20.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@release-it/conventional-changelog": "^5.0.0",
    "@swc/cli": "^0.1.65",
    "@swc/core": "^1.3.0",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "5.0.1",
    "@types/jest": "29.5.14",
    "@types/ms": "0.7.34",
    "@types/node": "22.10.5",
    "@types/passport-anonymous": "1.0.5",
    "@types/passport-jwt": "4.0.1",
    "@types/readline-sync": "^1.4.8",
    "@types/supertest": "6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "8.21.0",
    "@typescript-eslint/parser": "8.21.0",
    "env-cmd": "10.1.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.14.0",
    "hygen": "^6.2.11",
    "is-ci": "3.0.1",
    "jest": "29.7.0",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.0.0",
    "prompts": "^2.4.2",
    "release-it": "^15.0.0",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "swagger-ui-express": "^5.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.4.5",
    "webpack": "5.98.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 85,
        "functions": 90,
        "lines": 90
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "code",
    "export",
    "prompts",
    "ai",
    "conversation",
    "typescript",
    "nestjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/claude-code-exporter"
  },
  "bugs": {
    "url": "https://github.com/yourusername/claude-code-exporter/issues"
  },
  "homepage": "https://github.com/yourusername/claude-code-exporter#readme"
}
